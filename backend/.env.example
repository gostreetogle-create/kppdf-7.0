# === Server ===
NODE_ENV=development
PORT=3000

# === MongoDB (replica set required for multi-doc transactions per DOMAIN §5) ===
MONGO_URI=mongodb://localhost:27017/kppdf-7?replicaSet=rs0
MONGO_DB_NAME=kppdf-7

# === Redis (BullMQ) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === Storage (local disk MVP per ARCHITECTURE §6) ===
UPLOADS_DIR=./uploads
THUMBNAIL_WIDTH=320
THUMBNAIL_MEDIUM_WIDTH=1024

# === JWT ===
JWT_SECRET=change-me-to-32-char-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-different-string-32-char-min
JWT_REFRESH_EXPIRES_IN=7d

# === Admin bootstrap (used at OnApplicationBootstrap) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-run
ADMIN_EMAIL=admin@kppdf-7.local

# === Feature flags ===
ENABLE_QUEUE=true
LOG_LEVEL=log
CORS_ORIGINS=http://localhost:4200
